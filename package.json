{
  "name": "@ranchhandrobotics/babylon_ros",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ranch-Hand-Robotics/babylon_ros.git"
  },
  "description": "Babylon.JS abstractions for ROS 2",
  "version": "0.6.1",
  "main": "dist/ros.js",
  "types": "types/src/ros.d.ts",
  "exports": {
    ".": [
      "./dist/ros.js"
    ],
    "./openscad": [
      "./dist/openscad.js"
    ],
    "./openscadUtils": [
      "./dist/openscadUtils.js"
    ],
    "./workers": [
      "./dist/openscadWorker.js"
    ]
  },
  "files": [
    "./dist"
  ],
  "scripts": {
    "download-openscad": "node scripts/download-openscad-wasm.js",
    "build-openscad-from-source": "node scripts/build-openscad-from-source.js",
    "build-openscad-from-source-update": "node scripts/build-openscad-from-source.js --update",
    "build-all-local": "npm run build-openscad-from-source && npm run build",
    "prebuild": "npm run build-openscad-from-source",
    "test": "jest --ci --coverage --reporters=default --reporters=jest-junit",
    "build": "webpack --mode development",
    "postbuild": "node -e \"const fs=require('fs');fs.mkdirSync('web/workers',{recursive:true});fs.copyFileSync('dist/workers/openscadWorker.js','web/workers/openscadWorker.js');console.log('Copied worker to web/workers/');\"",
    "watch": "webpack --mode development --watch",
    "pretest": "npm run build",
    "prepublishOnly": "npm run build-openscad-from-source && webpack --mode=production",
    "serve": "npx http-server ./web -c-1 -o"
  },
  "keywords": [
    "babylonjs",
    "ros",
    "ros2"
  ],
  "browser": {
    "fs": false,
    "os": false,
    "path": false,
    "url": false
  },
  "jest-junit": {
    "outputDirectory": "reports",
    "outputName": "jest-junit.xml",
    "ancestorSeparator": " › ",
    "uniqueOutputName": "false",
    "suiteNameTemplate": "{filepath}",
    "classNameTemplate": "{classname}",
    "titleTemplate": "{title}"
  },
  "author": "Ranch Hand Robotics, LLC",
  "license": "MIT",
  "dependencies": {
    "@babylonjs/serializers": "^8.33.2",
    "@polyhobbyist/babylon-collada-loader": "^0.0.8",
    "@types/xml2js": "^0.4.14",
    "@types/xmldom": "^0.1.34",
    "babylonjs": "7.16.x",
    "babylonjs-gui": "7.16.x",
    "babylonjs-loaders": "7.16.x",
    "babylonjs-materials": "7.16.x",
    "babylonjs-viewer": "7.16.x",
    "buffer": "^6.0.3",
    "jest-environment-jsdom": "^29.7.0",
    "openscad-wasm-prebuilt": "^1.2.0",
    "stream-browserify": "^3.0.0",
    "string_decoder": "^1.3.0",
    "timers-browserify": "^2.0.12",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.12",
    "adm-zip": "^0.5.17",
    "copy-webpack-plugin": "^14.0.0",
    "jest": "^29.7.0",
    "jest-junit": "^17.0.0",
    "ts-jest": "^29.2.3",
    "ts-loader": "^9.5.1",
    "tslib": "^2.6.3",
    "typescript": "^5.8.2",
    "webpack": "^5.93.0",
    "webpack-cli": "^5.1.4"
  }
}
